{
  "name": "exo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "e2e:agent-harnesses": "tsx scripts/agent-harness-e2e.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix --deny-warnings .",
    "prepare": "node scripts/setup-hooks.mjs",
    "rendezvous:demo": "node scripts/rendezvous-demo.mjs",
    "slack:setup": "node scripts/slack-setup.mjs",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "docs:build": "vitepress build website/docs-src",
    "docs:dev": "vitepress dev website/docs-src",
    "website:build": "vite build --config website/vite.config.js && pnpm run docs:build",
    "website:dev": "vite --config website/vite.config.js",
    "website:preview": "vite preview --config website/vite.config.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@anthropic-ai/sdk": "^0.106.0",
    "@braintrust/lingua": "^0.1.0",
    "@braintrust/lingua-wasm": "^0.1.0",
    "@cursor/sdk": "^1.0.12",
    "@discordjs/voice": "^0.19.0",
    "@mozilla/readability": "^0.6.0",
    "@shadcn/react": "^0.1.0",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "braintrust": "3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.26.4",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.21.0",
    "openai": "6.33.0",
    "opusscript": "^0.1.1",
    "prism-media": "^1.3.5",
    "qrcode-terminal": "^0.12.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sodium-native": "^5.1.0",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.0",
    "vite": "8.0.3",
    "vitepress": "^1.6.4",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.26.2"
}
